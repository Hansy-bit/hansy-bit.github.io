source "https://rubygems.org"

# Standalone Jekyll 4 — compatible with modern Ruby (the github-pages
# gem pins old versions that break on Ruby 3.2+).
gem "jekyll", "~> 4.3"
gem "minima", "~> 2.5"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
end

# Local server
gem "webrick"

# Stdlib gems unbundled from Ruby 3.4+/4.0
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
